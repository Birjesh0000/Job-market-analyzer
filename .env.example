# Backend Configuration
BACKEND_PORT=5000
NODE_ENV=development

# Database Configuration
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
# For Local MongoDB: mongodb://localhost:27017
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/job_market_analyzer?retryWrites=true&w=majority&appName=Cluster0
DB_NAME=job_market_analyzer

# Scraper Configuration
SCRAPER_REQUEST_TIMEOUT=10
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=5

# Scheduler Configuration
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=24
ANALYTICS_INTERVAL_HOURS=12

# Data Sources
JOB_SOURCE_API=https://api.example.com/jobs
JOB_SOURCE_HEADERS={"User-Agent": "Mozilla/5.0"}

# Environment
DEBUG=false
